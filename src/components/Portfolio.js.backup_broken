window.actions.updateRealDistributionAmount = (key, value) => {
    const dist = state.portfolio.investment.realDistribution;
    if (!dist[key]) return;
    dist[key].amount = parseFloat(value) || 0;
    const total = dist.fixed.amount + dist.alternative.amount + dist.liquid.amount + dist.variable.amount;
    if (total > 0) {
        dist.fixed.percent = parseFloat(((dist.fixed.amount / total) * 100).toFixed(1));
        dist.alternative.percent = parseFloat(((dist.alternative.amount / total) * 100).toFixed(1));
        dist.liquid.percent = parseFloat(((dist.liquid.amount / total) * 100).toFixed(1));

        const sumOthers = dist.fixed.percent + dist.alternative.percent + dist.liquid.percent;
        dist.variable.percent = parseFloat((100 - sumOthers).toFixed(1));
    } else {
        dist.fixed.percent = 0;
        dist.alternative.percent = 0;
        dist.liquid.percent = 0;
        dist.variable.percent = 0;
    }
    updateUI();
};

