window.actions.addInvestment = () => {
    // Get values from inputs (using IDs for simplicity in this generated modal)
    const getVal = (id) => document.getElementById(id).value;

    const newInv = {
        id: Date.now(),
        date: getVal('inv-date'),
        objective: getVal('inv-objective'),
        classification: getVal('inv-classification'),
        tool: getVal('inv-tool'),
        period: getVal('inv-period'),
        rate: parseFloat(getVal('inv-rate')) || 0,
        amount: parseFloat(getVal('inv-amount')) || 0,
        expiry: getVal('inv-expiry'),
        status: getVal('inv-status')
    };

    if (!newInv.amount || !newInv.classification) {
        alert('Por favor ingrese al menos la clasificación y el monto.');
        return;
    }

    state.portfolio.investment.executedInvestments.push(newInv);

    // Recalculate Real Distribution
    const dist = state.portfolio.investment.realDistribution;
    const invs = state.portfolio.investment.executedInvestments;

    // Reset totals
    dist.fixed.amount = 0;
    dist.alternative.amount = 0;
    dist.liquid.amount = 0;
    dist.variable.amount = 0;

    invs.forEach(inv => {
        if (inv.classification === 'RENTA FIJA') dist.fixed.amount += inv.amount;
        if (inv.classification === 'ALTERNATIVO') dist.alternative.amount += inv.amount;
        if (inv.classification === 'LIQUIDO') dist.liquid.amount += inv.amount;
        if (inv.classification === 'RENTA VARIABLE') dist.variable.amount += inv.amount;
    });

    // Update percents
    // Update percents with strict 100% check
    const total = dist.fixed.amount + dist.alternative.amount + dist.liquid.amount + dist.variable.amount;

    if (total > 0) {
        dist.fixed.percent = parseFloat(((dist.fixed.amount / total) * 100).toFixed(1));
        dist.alternative.percent = parseFloat(((dist.alternative.amount / total) * 100).toFixed(1));
        dist.liquid.percent = parseFloat(((dist.liquid.amount / total) * 100).toFixed(1));

        const sumOthers = dist.fixed.percent + dist.alternative.percent + dist.liquid.percent;
        dist.variable.percent = parseFloat((100 - sumOthers).toFixed(1));
    } else {
        dist.fixed.percent = 0;
        dist.alternative.percent = 0;
        dist.liquid.percent = 0;
        dist.variable.percent = 0;
    }

    updateUI();
    // Keep modal open or clear inputs? Let's clear inputs
    ['inv-date', 'inv-objective', 'inv-tool', 'inv-period', 'inv-rate', 'inv-amount', 'inv-expiry', 'inv-status'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
};

